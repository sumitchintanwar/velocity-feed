      "id": 1,
      "panels": [],
      "title": "Platform Health",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "title": "Overall Availability",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(up{environment=\"$environment\", cluster=\"$cluster\"}) / count(up{environment=\"$environment\", cluster=\"$cluster\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.95
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          },
          "links": [
            {
              "title": "View Services Detailed Dashboard",
              "url": "/d/services-overview/services?var-environment=${environment}&var-cluster=${cluster}"
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
