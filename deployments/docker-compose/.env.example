# ==============================================================================
# RTMDS Docker Compose Environment Variables
# Copy this file to .env and modify as needed
# ==============================================================================

# Core Configuration
ENV=development
LOG_LEVEL=debug

# Infrastructure
POSTGRES_USER=rtmds_user
POSTGRES_PASSWORD=rtmds_secret_pass
POSTGRES_DB=rtmds
POSTGRES_PORT=5432

REDIS_PORT=6379

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_PORT=16686

# Platform Services
GATEWAY_PORT=8080
PUBLISHER_PORT=8081
FEED_GEN_PORT=8082
TOPIC_MGR_PORT=8083
REPLAY_API_PORT=8084
SNAPSHOT_SVC_PORT=8085
RECOVERY_MGR_PORT=8086
