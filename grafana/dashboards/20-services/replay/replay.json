{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Detailed view of the Replay service. Shows replay queue depth, message throughput, latency, errors, and recovery progress.\n\nOwner: Replay Team | Runbook: https://wiki.internal/runbooks/replay-service",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Platform Overview",
      "url": "/d/platform-overview",
      "type": "link",
      "icon": "external link",
      "tooltip": "Back to platform overview"
    },
    {
      "title": "Snapshot",
      "url": "/d/snapshot",
      "type": "link",
      "icon": "external link",
      "tooltip": "Snapshot service health"
    },
    {
      "title": "Recovery",
      "url": "/d/recovery",
      "type": "link",
      "icon": "external link",
      "tooltip": "Recovery operations"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 50000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Queue Depth",
      "description": "Current replay queue depth. High values indicate catch-up scenario or slow replay.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(replay_queue_depth{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"})",
          "legendFormat": "Queue",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Replay Rate",
      "description": "Current replay message rate. Measures replay throughput.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(replay_messages_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m]))",
          "legendFormat": "Messages/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Recovery Progress",
      "description": "Recovery progress percentage. 100% means fully caught up.",
      "type": "stat",
      "targets": [
        {
          "expr": "replay_recovery_progress_percent{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}",
          "legendFormat": "Progress",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Replay Errors/sec",
      "description": "Rate of replay errors. Any non-zero value requires investigation.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(replay_errors_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m]))",
          "legendFormat": "Errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Queue Depth Over Time",
      "description": "Queue depth over time. Decreasing trend indicates catch-up in progress.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(replay_queue_depth{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}) by (instance)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Replay Rate Over Time",
      "description": "Replay throughput over time. Shows replay capacity and progress.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(replay_messages_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])) by (instance)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Replay Latency Percentiles",
      "description": "P50, P95, P99 replay message latency. High latency indicates slow downstream.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(replay_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(replay_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(replay_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Time Since Last Replay",
      "description": "Time since last replayed message. Increasing values indicate stalled replay.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "time() - replay_last_message_timestamp{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}",
          "legendFormat": "Seconds",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Replay Errors Over Time",
      "description": "Replay error count by type. Helps identify data quality or delivery issues.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(replay_errors_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Gap Detection Events",
      "description": "Number of data gap detection events. Gaps trigger snapshot recovery.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(replay_gaps_detected_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])",
          "legendFormat": "Gaps/s",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Progress",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Recovery Progress %",
      "description": "Recovery progress percentage over time. 100% means fully recovered.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "replay_recovery_progress_percent{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}",
          "legendFormat": "Progress",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "ETA to Catchup",
      "description": "Estimated time to fully catch up (in seconds). Null when caught up.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "replay_eta_seconds{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}",
          "legendFormat": "ETA",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Messages Replayed",
      "description": "Total messages replayed. Cumulative counter shows replay history.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(replay_messages_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m]))",
          "legendFormat": "Messages",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 105,
      "title": "Queue Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "id": 14,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Queue Utilization %",
      "description": "Worker pool queue utilization as percentage of capacity. Growing queue is the LEADING indicator of dropped messages. Alert at 70% yellow, 90% red.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "replay_queue_depth{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"} / replay_queue_capacity{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "id": 15,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Queue Depth vs Capacity",
      "description": "Absolute queue depth (solid) vs capacity (dashed). When depth approaches capacity, messages will be dropped.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "replay_queue_depth{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}",
          "legendFormat": "{{instance}} depth",
          "refId": "A"
        },
        {
          "expr": "replay_queue_capacity{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}",
          "legendFormat": "{{instance}} capacity",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "id": 106,
      "title": "Database",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 49 },
      "id": 16,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "EventLog DB Status",
      "description": "EventLog PostgreSQL connectivity. DOWN means clients cannot recover via replay.",
      "type": "stat",
      "targets": [
        {
          "expr": "postgres_up{environment=\"$environment\", cluster=\"$cluster\", database=\"eventlog\"}",
          "legendFormat": "PostgreSQL",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 49 },
      "id": 17,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "DB Slow Queries/sec",
      "description": "Rate of slow queries on EventLog DB. High rate indicates need for index optimization.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(postgres_slow_queries_total{environment=\"$environment\", cluster=\"$cluster\", database=\"eventlog\"}[5m]))",
          "legendFormat": "Slow Queries/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 49 },
      "id": 18,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "DB Query Latency P99",
      "description": "P99 EventLog query latency. High latency slows replay recovery.",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(postgres_query_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", database=\"eventlog\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 49 },
      "id": 19,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "DB Connection Pool Usage",
      "description": "Percentage of DB connection pool in use. High usage causes query failures.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(postgres_active_connections{environment=\"$environment\", cluster=\"$cluster\", database=\"eventlog\"}) / sum(postgres_max_connections{environment=\"$environment\", cluster=\"$cluster\", database=\"eventlog\"})",
          "legendFormat": "Pool %",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "id": 107,
      "title": "Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 54 },
      "id": 20,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Snapshot Cache Hit Ratio",
      "description": "Cache hit ratio for snapshots. Low ratio means replay is hitting DB directly, crushing it during spike.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(snapshot_cache_hits_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])) / (sum(rate(snapshot_cache_hits_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])) + sum(rate(snapshot_cache_misses_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])))",
          "legendFormat": "Hit Ratio",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 58 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Cache Hits vs Misses Over Time",
      "description": "Snapshot cache hits and misses over time. Growing misses indicate cache warming needed.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(snapshot_cache_hits_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m]))",
          "legendFormat": "Hits/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(snapshot_cache_misses_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m]))",
          "legendFormat": "Misses/s",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 58 },
      "id": 22,
      "options": {
        "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Cache Hit Ratio Over Time",
      "description": "Snapshot cache hit ratio over time. Drops indicate cold cache causing DB pressure.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(snapshot_cache_hits_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])) by (instance) / (sum(rate(snapshot_cache_hits_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])) + sum(rate(snapshot_cache_misses_total{environment=\"$environment\", cluster=\"$cluster\", service=\"replay\"}[5m])))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
