              { "color": "green", "value": null },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Recovery Events",
      "description": "Recovery operations triggered across the platform. Spikes indicate service restarts or failovers. Correlate with error rate spikes.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(recovery_operations_total{environment=\"$environment\", cluster=\"$cluster\"}[5m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
