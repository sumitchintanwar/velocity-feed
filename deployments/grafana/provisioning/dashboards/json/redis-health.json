{
  "annotations": { "list": [] },
  "description": "Monitor Redis health: memory, connections, latency, and throughput. Redis is the message bus — if it's down, all clients see stale data.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Executive Overview", "url": "/d/executive-overview", "type": "link" },
    { "title": "Gateway Performance", "url": "/d/gateway-perf", "type": "link" }
  ],
  "panels": [
    {
      "title": "Redis Status",
      "description": "Redis reachability. 1 = up, 0 = down. If this drops to 0, all gateway clients see stale data immediately.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=\"redis\"}",
          "legendFormat": "status",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Connected Clients",
      "description": "Number of Redis client connections. Each gateway maintains a connection pool. A sudden drop means gateways lost connectivity.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "clients",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "description": "Redis memory consumption. Configured maxmemory is 256mb. At 80%, Redis may start evicting or rejecting writes.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Hit Rate",
      "description": "Redis key hit rate. Low hit rate means many misses, which for Pub/Sub indicates subscription churn (subscribing to new channels).",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Commands/Sec",
      "description": "Redis command throughput. Shows the overall load on Redis. Spikes indicate subscription churn or publish storms.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50000 },
              { "color": "red", "value": 100000 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "cmds/sec",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Evicted Keys",
      "description": "Keys evicted due to maxmemory. Non-zero means Redis is at capacity and actively evicting data. For Pub/Sub this indicates subscription overload.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total[5m]) * 300",
          "legendFormat": "evicted/5m",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Publish Operations/Sec",
      "description": "Redis PUBLISH commands per second. This is the primary write path for market data distribution.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never"
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(redis_commands_total{cmd=\"publish\"}[5m])",
          "legendFormat": "publish",
          "refId": "A"
        },
        {
          "expr": "rate(redis_commands_total{cmd=\"subscribe\"}[5m]) + rate(redis_commands_total{cmd=\"unsubscribe\"}[5m])",
          "legendFormat": "subscribe/unsubscribe",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Network Throughput",
      "description": "Redis network I/O. Inbound = data received from gateways (publishes). Outbound = data sent to gateways (messages).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [
        {
          "expr": "rate(redis_net_input_bytes_total[5m])",
          "legendFormat": "inbound",
          "refId": "A"
        },
        {
          "expr": "rate(redis_net_output_bytes_total[5m])",
          "legendFormat": "outbound",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Redis Latency",
      "description": "Average command processing latency. > 10ms indicates Redis is overloaded. Critical for market data — publish latency directly impacts delivery latency.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "targets": [
        {
          "expr": "rate(redis_commands_duration_seconds_total[5m]) / rate(redis_commands_processed_total[5m])",
          "legendFormat": "avg latency",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage Over Time",
      "description": "Redis memory consumption trend. A steady increase indicates subscription growth or payload size increase.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Connected Clients Over Time",
      "description": "Redis client connections trend. Each gateway maintains connections — a steady count indicates stable gateway operations.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "clients",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["rtmds", "redis", "infrastructure"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "RTMDS Redis Health",
  "uid": "redis-health",
  "version": 1
}
