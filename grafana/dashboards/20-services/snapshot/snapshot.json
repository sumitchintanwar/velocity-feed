{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Detailed view of the Snapshot service. Shows snapshot generation rate, size, latency, staleness, and storage health.\n\nOwner: Snapshot Team | Runbook: https://wiki.internal/runbooks/snapshot-service",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Platform Overview",
      "url": "/d/platform-overview",
      "type": "link",
      "icon": "external link",
      "tooltip": "Back to platform overview"
    },
    {
      "title": "Replay",
      "url": "/d/replay",
      "type": "link",
      "icon": "external link",
      "tooltip": "Replay service health"
    },
    {
      "title": "Redis",
      "url": "/d/redis",
      "type": "link",
      "icon": "external link",
      "tooltip": "Redis storage health"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Snapshot Rate",
      "description": "Current snapshot generation rate (per second).",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(snapshot_total{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}[5m]))",
          "legendFormat": "Snapshots/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1048576 },
              { "color": "red", "value": 10485760 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Avg Snapshot Size",
      "description": "Average snapshot message size. Large snapshots indicate complex order books.",
      "type": "stat",
      "targets": [
        {
          "expr": "snapshot_message_size_bytes{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}",
          "legendFormat": "Size",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "mappings": [
          { "options": { "0": { "text": "STALE", "color": "red" }, "1": { "text": "FRESH", "color": "green" } }, "type": "value" }
        ],
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Snapshot Freshness",
      "description": "Whether latest snapshot is fresh (within threshold) or stale.",
      "type": "stat",
      "targets": [
        {
          "expr": "snapshot_is_fresh{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}",
          "legendFormat": "Fresh",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Generation Errors/sec",
      "description": "Rate of snapshot generation errors. Non-zero indicates failures.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(snapshot_errors_total{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}[5m]))",
          "legendFormat": "Errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Snapshot Rate Over Time",
      "description": "Snapshot generation rate over time. Shows snapshot cadence stability.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(snapshot_total{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}[5m])) by (instance)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Snapshot Size Over Time",
      "description": "Snapshot size over time. Growing sizes indicate order book complexity growth.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "snapshot_message_size_bytes{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Snapshot Generation Latency",
      "description": "P50, P95, P99 snapshot generation latency. High latency impacts data freshness.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(snapshot_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(snapshot_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(snapshot_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Time Since Last Snapshot",
      "description": "Time since last snapshot per symbol. Increasing values indicate stalled generation.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "time() - snapshot_last_generated_timestamp{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}",
          "legendFormat": "{{symbol}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Snapshot Errors Over Time",
      "description": "Snapshot generation errors by type. Helps diagnose failure patterns.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(snapshot_errors_total{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}[5m])) by (error_type)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Serialization Errors",
      "description": "Snapshot serialization errors. Indicates data corruption or encoding issues.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(snapshot_serialization_errors_total{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}[5m])",
          "legendFormat": "Errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Storage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Redis Storage Used",
      "description": "Redis storage used for snapshots. Growing indicates memory pressure.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "snapshot_storage_bytes{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}",
          "legendFormat": "Storage",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Active Snapshots",
      "description": "Number of active snapshots being held in cache.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "snapshot_active_count{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Symbols Tracked",
      "description": "Number of symbols being tracked for snapshots.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "snapshot_symbols_count{environment=\"$environment\", cluster=\"$cluster\", service=\"snapshot\"}",
          "legendFormat": "Symbols",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["snapshot", "service", "rtmds"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data Source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "query": "label_values(http_requests_total, environment)",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "current": { "selected": true, "text": "production", "value": "production" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "query": "label_values(http_requests_total{environment=\"$environment\"}, cluster)",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "query": "label_values(snapshot_total{environment=\"$environment\", cluster=\"$cluster\"}, instance)",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Service - Snapshot",
  "uid": "snapshot",
  "version": 1
}