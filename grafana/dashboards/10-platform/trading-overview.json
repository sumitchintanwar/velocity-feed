{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Business-level view of trading activity. Shows market data throughput, active clients, exchange connectivity, and business KPIs.\n\nOwner: Market Data Engineering | Runbook: https://wiki.internal/runbooks/trading-overview",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Platform Overview",
      "url": "/d/platform-overview",
      "type": "link",
      "icon": "external link",
      "tooltip": "Platform health overview"
    },
    {
      "title": "Publisher",
      "url": "/d/publisher?var-service=publisher",
      "type": "link",
      "icon": "external link",
      "tooltip": "Publisher service details"
    },
    {
      "title": "Replay",
      "url": "/d/replay",
      "type": "link",
      "icon": "external link",
      "tooltip": "Replay service details"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Trading Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Active Subscribers",
      "description": "Number of active WebSocket subscribers connected to the platform. Represents current trading desk load.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(gateway_connections_active{environment=\"$environment\", cluster=\"$cluster\"})",
          "legendFormat": "Subscribers",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 100000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Market Data Updates/sec",
      "description": "Rate of market data updates being published to clients. Primary business throughput metric.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(publisher_messages_total{environment=\"$environment\", cluster=\"$cluster\"}[5m]))",
          "legendFormat": "Updates/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Publish Latency P99",
      "description": "99th percentile latency from exchange receipt to client delivery. Critical for trading desk SLA.",
      "type": "stat",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(publisher_publish_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Active Symbols",
      "description": "Number of unique symbols with active subscriptions. Higher counts indicate broader market activity.",
      "type": "stat",
      "targets": [
        {
          "expr": "count(count by (symbol) (gateway_messages_sent_total{environment=\"$environment\"} > 0)) or vector(0)",
          "legendFormat": "Symbols",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Delivery Success Rate",
      "description": "Percentage of messages successfully delivered to clients. Any drop below 99.9% requires immediate investigation.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(gateway_messages_sent_total{environment=\"$environment\", cluster=\"$cluster\"}[5m])) / sum(rate(publisher_messages_total{environment=\"$environment\", cluster=\"$cluster\"}[5m]))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Market Data Flow",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Messages by Exchange",
      "description": "Message throughput broken down by exchange. Helps identify which exchange is generating the most traffic.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(publisher_messages_total{environment=\"$environment\", cluster=\"$cluster\"}[5m])) by (exchange)",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Connections by Gateway",
      "description": "Active connections broken down by gateway instance. Shows load distribution across gateways.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gateway_connections_active{environment=\"$environment\", cluster=\"$cluster\"}",
          "legendFormat": "{{gateway_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Replay & Snapshots",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Replay Requests",
      "description": "Rate of historical replay requests. Spikes indicate trading desk activity or regulatory inquiries.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(replay_requests_total{environment=\"$environment\", cluster=\"$cluster\"}[5m]))",
          "legendFormat": "Replay Requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Snapshots Created",
      "description": "Rate of snapshot creation. Indicates data persistence activity and checkpoint frequency.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(snapshots_created_total{environment=\"$environment\", cluster=\"$cluster\"}[5m]))",
          "legendFormat": "Snapshots/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Replay Latency P99",
      "description": "99th percentile replay request duration. High latency indicates large replay windows or storage bottlenecks.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(replay_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["trading", "business", "rtmds"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data Source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "query": "label_values(http_requests_total, environment)",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "current": { "selected": true, "text": "production", "value": "production" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "query": "label_values(http_requests_total{environment=\"$environment\"}, cluster)",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Trading - Overview",
  "uid": "trading-overview",
  "version": 1
}
