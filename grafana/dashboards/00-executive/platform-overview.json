      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Total Goroutines",
      "description": "Total goroutines across all services. High counts indicate concurrency issues or goroutine leaks.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(go_goroutines{environment=\"$environment\", cluster=\"$cluster\"})",
          "legendFormat": "Goroutines",
          "refId": "A"
