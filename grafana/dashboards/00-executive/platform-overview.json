      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Active Gateways",
      "description": "Number of active gateway instances. A drop indicates gateway pod failures.",
      "type": "stat",
      "targets": [
        {
          "expr": "count(gateway_connections_active{environment=\"$environment\"} > 0) or vector(0)",
          "legendFormat": "Gateways",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
