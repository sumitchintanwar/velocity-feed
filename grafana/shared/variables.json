{
  "_comment": "Shared variable definitions for all RTMDS Grafana dashboards. Copy these into each dashboard's 'templating' section.",
  "_documentation": "These variables provide consistent filtering across all dashboards. They cascade from environment → cluster → namespace → service → instance.",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data Source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "query": "label_values(http_requests_total, environment)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {
          "selected": true,
          "text": "production",
          "value": "production"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "query": "label_values(http_requests_total{environment=\"$environment\"}, cluster)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "query": "label_values(http_requests_total{cluster=\"$cluster\"}, namespace)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "query": "label_values(http_requests_total{namespace=\"$namespace\"}, service)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "query": "label_values(http_requests_total{service=~\"$service\"}, instance)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      },
      {
        "name": "gateway",
        "label": "Gateway",
        "type": "query",
        "query": "label_values(gateway_connections_active, gateway_id)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "options": [],
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "skipUrlSync": false
      }
    ]
  }
}
