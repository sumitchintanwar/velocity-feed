        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Redis Status",
      "description": "Redis connectivity status. DOWN indicates Redis is unreachable, which breaks pub/sub message flow.",
      "type": "stat",
      "targets": [
        {
          "expr": "redis_up{environment=\"$environment\"}",
          "legendFormat": "Redis",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
