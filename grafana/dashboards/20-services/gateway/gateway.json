{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Detailed view of the Gateway service. Shows WebSocket connections, message routing, latency, errors, and runtime health.\n\nOwner: Gateway Team | Runbook: https://wiki.internal/runbooks/gateway-service",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Platform Overview",
      "url": "/d/platform-overview",
      "type": "link",
      "icon": "external link",
      "tooltip": "Back to platform overview"
    },
    {
      "title": "Kubernetes",
      "url": "/d/kubernetes",
      "type": "link",
      "icon": "external link",
      "tooltip": "Kubernetes cluster health"
    },
    {
      "title": "Runtime",
      "url": "/d/runtime?var-service=gateway",
      "type": "link",
      "icon": "external link",
      "tooltip": "Go runtime metrics"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "displayMode": "gradient",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Connections Per Gateway",
      "description": "Active WebSocket connections per gateway instance. Use to identify uneven load distribution or gateway-specific issues.",
      "type": "bargauge",
      "targets": [
        {
          "expr": "gateway_connections_active{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 50000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Message Rate",
      "description": "Incoming message rate across all gateways. Measures client activity.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(gateway_messages_total{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m]))",
          "legendFormat": "Messages/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Connection Errors/sec",
      "description": "Rate of connection errors. Non-zero values indicate authentication failures or protocol issues.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(gateway_connection_errors_total{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m]))",
          "legendFormat": "Errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Disconnections/sec",
      "description": "Rate of client disconnections. High rates indicate unstable clients or gateway issues.",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(gateway_disconnections_total{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m]))",
          "legendFormat": "Drops/s",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Connections Over Time",
      "description": "Active connections per gateway instance over time. Helps identify load distribution issues.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "gateway_connections_active{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Message Rate Over Time",
      "description": "Message throughput per gateway instance. Shows traffic patterns and anomalies.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(gateway_messages_total{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m])) by (instance)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Message Processing Latency Percentiles",
      "description": "P50, P95, P99 message processing latency. High latency impacts client experience.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_message_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_message_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_message_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "heatmap",
            "fillOpacity": 80
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 8,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": { "mode": "scheme", "name": "Oranges", "scheme": "Oranges", "fill": "dark-orange", "scale": "exponential", "exponent": 0.5 },
        "exemplars": { "color": "rgba(255, 0, 255, 0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "le" },
        "tooltip": { "mode": "single", "showColorScale": true, "yHistogram": true },
        "yAxis": { "axisLabel": "", "axisPlacement": "auto", "auto": true, "decimals": null, "format": "s", "logBase": 1, "min": null, "max": null, "reverse": false }
      },
      "title": "Latency Heatmap",
      "description": "Latency distribution heatmap. Darker colors indicate higher request counts at that latency.",
      "type": "heatmap",
      "targets": [
        {
          "expr": "sum(increase(gateway_message_duration_seconds_bucket{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Disconnect Reasons",
      "description": "Client disconnection breakdown by reason. Client closed = normal. Heartbeat Timeout = network issues. Server Error = gateway problems. Use to route to correct team.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(gateway_disconnections_total{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "HTTP Errors by Status",
      "description": "HTTP error breakdown by status code. 5xx indicates server errors, 4xx indicates client errors.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\", status=~\"[45]..\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Goroutines",
      "description": "Goroutine count per instance. Growing count indicates goroutine leaks.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "go_goroutines{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Memory Usage",
      "description": "Heap allocation per instance. Memory growth indicates allocation pressure or leaks.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "GC Duration",
      "description": "GC pause duration per instance. High GC duration correlates with latency spikes.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum{environment=\"$environment\", cluster=\"$cluster\", service=\"gateway\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["gateway", "service", "rtmds"],
