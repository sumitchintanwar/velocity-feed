{
  "annotations": { "list": [] },
  "description": "Monitor gateway instances: connections, latency, slow consumers, and heartbeat health. Answers: Are clients evenly distributed? Are slow consumers increasing?",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Executive Overview", "url": "/d/executive-overview", "type": "link" },
    { "title": "Redis Health", "url": "/d/redis-health", "type": "link" },
    { "title": "Reliability", "url": "/d/reliability", "type": "link" }
  ],
  "panels": [
    {
      "title": "Active Connections",
      "description": "Current WebSocket connections per gateway instance. Uneven distribution may indicate load balancer misconfiguration.",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "green", "value": 500 }
            ]
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rtmds_websocket_connections_active) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Slow Consumers",
      "description": "Current slow consumers per gateway. > 10 indicates systemic backpressure. Clients will be disconnected after 100 consecutive drops.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum(rtmds_websocket_slow_consumers) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Write Errors",
      "description": "WebSocket write errors per gateway. Non-zero values indicate client disconnects during write or socket buffer exhaustion.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(rtmds_websocket_write_errors_total[5m])) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Connection Growth",
      "description": "WebSocket connections over time. Shows opens, closes, and active count. Sudden drops indicate incidents.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rtmds_websocket_connections_active)",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "sum(rate(rtmds_websocket_connections_opened_total[5m])) * 300",
          "legendFormat": "opens/5m",
          "refId": "B"
        },
        {
          "expr": "sum(rate(rtmds_websocket_connections_closed_total[5m])) * 300",
          "legendFormat": "closes/5m",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Messages Written Per Gateway",
      "description": "Messages written to WebSocket clients per gateway. Shows load distribution across instances.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(rtmds_websocket_messages_written_total[5m])) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Delivery Latency P50 / P95 / P99",
      "description": "End-to-end latency from event creation to WebSocket delivery, per percentile. P99 > 500ms means clients see stale data.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(rtmds_websocket_delivery_latency_seconds_bucket[5m]))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(rtmds_websocket_delivery_latency_seconds_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(rtmds_websocket_delivery_latency_seconds_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Delivery Latency Heatmap",
      "description": "Distribution of delivery latency across all buckets. Shows the density of latency values — darker regions indicate where most requests land.",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "s",
          "decimals": 1
        },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges",
          "fill": "dark"
        },
        "cellGap": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": { "type": "log", "log": 2 }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(increase(rtmds_websocket_delivery_latency_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{ le }}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "title": "Bytes Sent / Sec",
      "description": "WebSocket bandwidth utilization. Useful for capacity planning and detecting anomalous traffic patterns.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(rtmds_websocket_bytes_sent_total[5m])) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Heartbeat Timeouts",
      "description": "Clients disconnected due to heartbeat timeout. Spikes indicate network issues or client crashes.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(increase(rtmds_websocket_heartbeat_timeouts_total[5m])) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reconnect Attempts",
      "description": "Client reconnection attempts. Spikes indicate instability — gateway restarts, network partitions, or load balancer issues.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 20 },
      "targets": [
        {
          "expr": "sum(increase(rtmds_websocket_reconnect_attempts_total[5m])) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Sequence Gaps",
      "description": "Sequence gaps detected in the writePump. Indicates out-of-order message delivery, which may cause client-side data inconsistency.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 20 },
      "targets": [
        {
          "expr": "sum(increase(rtmds_websocket_sequence_gaps_total[5m])) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Ping Latency",
      "description": "WebSocket ping/pong round-trip time. High values indicate network latency between gateway and clients.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rtmds_websocket_ping_latency_seconds_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(rtmds_websocket_ping_latency_seconds_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Active Subscriptions",
      "description": "Current active WebSocket subscriptions across gateways. Shows how many symbol streams are active.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "targets": [
        {
          "expr": "sum(rtmds_websocket_active_subscriptions) by (instance)",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["rtmds", "gateway", "performance"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "RTMDS Gateway Performance",
  "uid": "gateway-perf",
  "version": 1
}
